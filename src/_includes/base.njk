<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>
  <a href="#main-content">{{ header[locale].skipLink }}</a>

  <header>
    <a href="/{{ locale }}/" aria-label="{{ header[locale].goHomepage }}">Jean-Charles Le Tousey</a>
  </header>

  <main id="main-content" tabindex="-1">
    <h1>{{ title }}</h1>
    {{ content | safe }}
  </main>
</body>
</html>