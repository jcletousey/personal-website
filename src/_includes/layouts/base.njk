<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>
  <a href="#main-content" class="visually-hidden">{{ header[locale].skipLink }}</a>

  <header class="header" role="banner">
    <a class="header__brand" href="/{{ locale }}/" aria-label="{{ header[locale].goToHomepage }}">{{ site.name }}</a>

    <nav class="header__nav" role="navigation">
      {% set navPages = collections["all_" + locale] | eleventyNavigation %}
      <ul class="nav__menu">
      {% for entry in navPages %}
        <li class="nav__item">
          <a href="{{ entry.url | url }}">{{ entry.title }}</a>
        </li>
      {% endfor %}
      </ul>
    </nav>

    <div class="header__languages">
      {% for key, text in site.locales %}
        {% if key != locale %}
        <a href="/{{ key }}/" title="{{ text }}">{{ key | upper }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </header>

  <main id="main-content" tabindex="-1" role="main">
    <div class="container">
    <h1>{{ title }}</h1>
    {{ content | safe }}
    </div>
  </main>

  <footer>
    <div class="container">
      {{ footer[locale].eleventy | renderMarkdown | safe }}
    </div>
  </footer>
</body>
</html>